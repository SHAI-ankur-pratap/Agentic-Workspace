# TCMS — Environment Variables
# Copy to .env and fill in values before running

# ── Core ──────────────────────────────────────────────────────────────────────
# Secret key for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=change-me-before-production

# Database URL — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///./tcms.db
# DATABASE_URL=postgresql://user:password@localhost:5432/tcms

# ── LLM (via LiteLLM proxy) ───────────────────────────────────────────────────
LITELLM_API_BASE=https://api.shorthills.ai/v1
LITELLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── GitHub Integration ────────────────────────────────────────────────────────
# Webhook secret — set same value in GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret
# PAT for posting PR comments (needs repo:read, PR:write)
GITHUB_TOKEN=ghp_...

# ── Slack Notifications ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Weekly Digest Email ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@shorthills.ai
SMTP_PASSWORD=app-password-here
DIGEST_FROM_EMAIL=noreply@shorthills.ai
